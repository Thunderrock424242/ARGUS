{
  "name": "argus-intelligence-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "brain:dev": "node scripts/run-wrangler.mjs dev",
    "brain:check": "node scripts/run-wrangler.mjs deploy --dry-run",
    "brain:deploy": "node scripts/run-wrangler.mjs deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:rendered": "npm run build && node --test tests/rendered-html.test.mjs",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build",
    "lint": "eslint . --ignore-pattern dist",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.25.0",
    "maplibre-gl": "^5.24.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.18.1",
    "recharts": "^3.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@cloudflare/workers-types": "^5.20260719.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "14.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    }
  },
  "type": "module"
}
