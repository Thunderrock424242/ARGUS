# Server-only secret. Leave empty to keep every administrative API disabled.
# Generate a high-entropy value locally; never expose it through NEXT_PUBLIC_*.
ARGUS_ADMIN_TOKEN=

# The MVP provider is the bundled, network-free fictional dataset.
ARGUS_DATA_PROVIDER=mock

# Live collection is not enabled from web requests. Production workers should
# receive mode and source credentials through the hosting secret manager.
ARGUS_COLLECTOR_MODE=dry-run
