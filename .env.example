# Server-only secret. Leave empty to keep every administrative API disabled.
# Generate a high-entropy value locally; never expose it through VITE_*.
ARGUS_ADMIN_TOKEN=

# Live collection is not enabled from web requests. Production workers should
# receive mode and source credentials through the hosting secret manager.
ARGUS_COLLECTOR_MODE=dry-run

# Applied by the Worker's scheduled D1 retention handler. The deployed value
# lives in wrangler.jsonc and is clamped to 30-3650 days.
RETENTION_DAYS=180

# Public URL of the separately deployed ARGUS brain Worker. Leave empty to use
# the bundled deterministic browser fallback.
VITE_ARGUS_API_URL=
