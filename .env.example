# Server-only secret. Leave empty to keep every administrative API disabled.
# Generate a high-entropy value locally; never expose it through VITE_*.
ARGUS_ADMIN_TOKEN=

# GitHub OAuth identity. The client ID is public by protocol, but both values
# are stored as Worker secrets so deployment configuration has one safe path.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Must exactly match the GitHub OAuth App callback URL.
AUTH_CALLBACK_URL=https://thunderrock424242.github.io/ARGUS/
AUTH_SESSION_TTL_SECONDS=28800

# The live collector pilot is disabled by default. USGS requires no secret.
# The Guardian and X values must be stored with `wrangler secret put` in a
# deployed Worker; do not expose either value through VITE_*.
COLLECTOR_PILOT_ENABLED=false
COLLECTOR_USGS_ENABLED=true
COLLECTOR_GUARDIAN_ENABLED=true
COLLECTOR_X_ENABLED=false
COLLECTOR_GUARDIAN_QUERY=world
COLLECTOR_X_QUERY=(earthquake OR wildfire OR cyclone OR flood) lang:en -is:retweet
GUARDIAN_API_KEY=
X_BEARER_TOKEN=

# Applied by the Worker's scheduled D1 retention handler. The deployed value
# lives in wrangler.jsonc and is clamped to 30-3650 days.
RETENTION_DAYS=180

# Public, non-secret browser switch. Set this and ARGUS_DEMO_ENABLED to false
# together to suppress fixture fallback, demo-only screens, and demo seeding.
ARGUS_DEMO_ENABLED=true
VITE_ARGUS_DEMO_ENABLED=true

# Public URL of the separately deployed ARGUS brain Worker. Leave empty to use
# the bundled deterministic browser fallback.
VITE_ARGUS_API_URL=
